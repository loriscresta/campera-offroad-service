# Chiave API che Campera Trail Planner usera nell'header X-API-Key
API_KEY=cambia-questa-chiave

# Database PostGIS
POSTGRES_USER=campera
POSTGRES_PASSWORD=campera
POSTGRES_DB=campera_offroad
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Zona da importare. Default: tutto Piemonte + Liguria (bbox di inquadramento).
# Formato: min_lon,min_lat,max_lon,max_lat
# Nota: per ritagliare ESATTAMENTE sui confini regionali, usa in import_osm.sh
#   osmium extract -p piemonte_liguria.geojson  (poligono confini, non bbox).
BBOX=6.60,43.75,10.15,46.50

# (zona pilota ridotta usata nei primi test — Appennino ligure-piemontese)
# BBOX=8.45,44.40,9.20,44.75

# Estratto Geofabrik di partenza (copre Liguria + Piemonte)
GEOFABRIK_URL=https://download.geofabrik.de/europe/italy/nord-ovest-latest.osm.pbf
